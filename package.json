{
  "name": "trancut",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "deploy": "opennextjs-cloudflare build && wrangler deploy",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "db:migrate:local": "wrangler d1 migrations apply trancut-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply trancut-db --remote"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "better-auth": "^1.6.23",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "wrangler": "^4.105.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260706.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "typescript": "^5"
  }
}
